{
  "mcpServers": {
    "gopls": {
      "command": "mcp-gopls",
      "args": ["-workspace", "${PROJECT_ROOT}"]{{ if .work.enabled }},
      "env": {
        "GOPRIVATE": "{{ .work.goprivate }}"
      }{{ end }}
    },
    "svelte-docs": {
      "command": "npx",
      "args": ["-y", "@spences10/mcp-svelte-docs"]
    }
  }
}
